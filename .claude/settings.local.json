{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(gh issue --help:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(curl:*)",
      "Bash(sh:*)",
      "Bash(sudo apt-get update:*)",
      "Bash(apt-cache search:*)",
      "Bash(apt-cache:*)",
      "WebFetch(domain:dyalog.github.io)",
      "Bash(/usr/bin/dyalogscript:*)",
      "Bash(/usr/local/bin/dyalogscript:*)",
      "WebSearch"
    ]
  },
  "plansDirectory": "docs/plans",
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh"
  }
}